# Model discovery roots (required)
# Semicolon-separated directories. Only these directories are scanned for subfolders
# containing heads.pt. Each such subfolder becomes a model profile.
# Example:
# MODEL_DIRS=models;../arabic-itsm-classification/models
MODEL_DIRS=models

# Optional default model id for /classify (must exist in discovered profiles)
# If unset, the first model in MODEL_DIRS (alphabetically) is used.
# DEFAULT_MODEL_ID=marbert_l2_best

# Optional: force device
# DEVICE=cpu

# ── Multi-task production model (optional shortcut) ──────────────────────────
# After running kaggle_train_multitask_arabic_itsm_classification on Kaggle
# and copying the checkpoint locally, set MULTITASK_MODEL_PATH to register it
# directly without needing it inside a MODEL_DIRS folder.
#
# MULTITASK_MODEL_PATH=models/marbert_multi_task_best
#
# The multi-task checkpoint has 5 heads (l1, l2, l3, priority, sentiment)
# in a single 621 MB forward pass — the production model.

# ── HuggingFace cache location ────────────────────────────────────────────────
# By default HuggingFace caches models in C:\Users\<you>\.cache\huggingface\
# which can fill your C drive. Redirect it to another drive by setting HF_HOME.
# load_dotenv() runs before any model loading, so this works correctly.
#
# HF_HOME=D:/AI/cache/huggingface

# ── Comparative evaluation defaults (used by /api/research/run) ───────────────
# Optional: pin which two profiles to compare by model_id.
# If *_PATH is not set and the id exists in discovered MODEL_DIRS, the profile path is used.
#
# COMPARISON_MODEL_A_ID=marbert-arabic-itsm-l3-categories
# COMPARISON_MODEL_B_ID=marbert-arabic-itsm-multitask
#
# Optional explicit paths (local or HF model repo id accepted by classifier):
# COMPARISON_MODEL_A_PATH=models/marbert_l1_l2_l3_best
# COMPARISON_MODEL_B_PATH=models/marbert_multi_task_best
#
# Dataset input for comparison run:
# 1) Prefer local CSV path if available:
# COMPARISON_DATASET_CSV=data/processed/test.csv
# 2) Optional URL fallback when local CSV is unavailable:
# COMPARISON_DATASET_URL=https://example.com/test.csv
#
# Public references embedded in generated article/report:
# COMPARISON_MODEL_A_URL=https://huggingface.co/albaz2000/marbert-arabic-itsm-l3-categories
# COMPARISON_MODEL_B_URL=https://huggingface.co/albaz2000/marbert-arabic-itsm-multitask
# COMPARISON_DATASET_HF_URL=https://huggingface.co/datasets/albaz2000/arabic-itsm-dataset
